apiVersion: v1
kind: ConfigMap
metadata:
  name: outline-config
data:
  URL: https://wiki.{{ nom_club }}.etsmtl.club
  REDIS_URL: redis://{{ nom_club }}-redis-svc.{{ nom_club }}-outlinewiki.svc.cluster.local:6379
  DEFAULT_LANGUAGE: fr_FR
  FILE_STORAGE: local
  FILE_STORAGE_LOCAL_ROOT_DIR: /var/lib/outline/data
  FILE_STORAGE_UPLOAD_MAX_SIZE: "262144000"
  OIDC_AUTH_URI: https://auth.etsmtl.club/application/o/authorize/
  OIDC_DISPLAY_NAME: OpenID Connect
  OIDC_LOGOUT_URI: https://auth.etsmtl.club/application/o/outlinewiki-{{ nom_club }}/end-session/
  OIDC_SCOPES: openid profile email
  OIDC_TOKEN_URI: https://auth.etsmtl.club/application/o/token/
  OIDC_USERINFO_URI: https://auth.etsmtl.club/application/o/userinfo/
  OIDC_USERNAME_CLAIM: preferred_username
